# GroupChat Contract Configuration

# GroupChat round is derived from extensionCenterAddress.joinAddress().originBlocks/phaseBlocks.

# ExtensionCenter used by typed decentralized managers
extensionCenterAddress=0x5EC6968225d640f5A6DD8EaB2574539E506Bc184

# GroupJoin used by chain-group managed chat scope source
groupJoinAddress=0xF61861699CdDfBD74395060Ea36A040b3FB8251A

# Recent rounds scanned by action chat managers
actionRecentRounds=3

# GovVotedDenySource blacklist threshold ratio, precision 1e18.
# 3000000000000000 = 0.3% blacklist effective threshold.
denyThresholdRatio=3000000000000000

# Max AdminDenySource admin NFT count per group
maxAdminIds=20

# Optional immutable plugin slots used by typed decentralized managers
groupChatBeforePostPluginAddress=0x0000000000000000000000000000000000000000
groupChatAfterPostPluginAddress=0x0000000000000000000000000000000000000000
